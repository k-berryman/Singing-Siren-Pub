        {
          "alias": false,
          "_styles": {
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "input": {
              "background-color": "rgba(0, 0, 0, 0)",
              "border-radius": "0",
              "border": "none!important",
              "box-shadow": "none",
              "border-bottom": "1px solid #0c5b47!important"
            },
            "textarea": {
              "background-color": "rgba(0, 0, 0, 0)",
              "border-radius": "0",
              "border": "none!important",
              "box-shadow": "none",
              "border-bottom": "1px solid #0c5b47!important"
            },
            "a": {
              "padding": "0",
              "border": "0px",
              "transition": "all 0.2s ease-out",
              "padding-left": "0",
              "padding-right": "0",
              "word-break": "normal",
              "justify-content": "center"
            },
            ".btn": {
              "white-space": "nowrap",
              "padding-left": "30px",
              "padding-right": "30px",
              "margin-top": "25px"
            },
            ".form-group": {
              "display": "inline-block",
              "margin-right": "0"
            },
            ".left": {
              "background-color": "#f2f2f2",
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "center"
            },
            ".mbr-section-title": {
              "padding-bottom": "10px",
              "color": "#0c5b47",
              "font-size": "42px"
            },
            ".right": {
              "padding-top": "80px",
              "padding-bottom": "80px",
              "padding-left": "5%",
              "padding-right": "5%",
              "display": "inline-block"
            },
            ".container": {
              "display": "flex",
              "padding": "0",
              "margin": "auto",
              "max-width": "initial"
            },
            "@media (max-width: 690px)": {
              ".right, .left": {
                "width": "100%"
              },
              ".container": {
                "display": "block"
              },
              ".google-map": {
                "height": "27rem"
              },
              ".right": {
                "padding-top": "49px",
                "padding-bottom": "40px"
              }
            },
            "@media (min-width: 690px)": {
              ".right, .left": {
                "width": "50%"
              }
            },
            ".desc": {
              "color": "#0c5b47"
            },
            ".google-map": {
              "filter": "grayscale(0.9)",
              "height": "31rem",
              "position": "relative",
              "iframe": {
                "height": "100%",
                "width": "100%"
              },
              "[data-state-details]": {
                "color": "#6b6763",
                "font-family": "Montserrat",
                "height": "1.5em",
                "margin-top": "-0.75em",
                "padding-left": "1.25rem",
                "padding-right": "1.25rem",
                "position": "absolute",
                "text-align": "center",
                "top": "50%",
                "width": "100%"
              },
              "&[data-state]": {
                "background": "#e9e5dc"
              },
              "&[data-state=\"loading\"]": {
                "[data-state-details]": {
                  "display": "none"
                },
                "&::after": {}
              }
            },
            "input, textarea": {
              "background-color": "rgba(0, 0, 0, 0)",
              "border-radius": "0"
            },
            ".mbr-text": {
              "padding-bottom": "20px"
            },
            ".form-control": {
              "font-style": "italic",
              "color": "#1b745e !important",
              "font-family": "crimson text,serif"
            }
          },
          "_name": "footer2",
          "_sourceTheme": "restaurantm4",
          "_customHTML": "<section class=\"footer3\" group=\"Footer\" global once=\"footers\">\n    <mbr-parameters>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Map</header>\n        <input type=\"map\" title=\"Address\" name=\"googleMap\" place-id=\"ocean city\" value=\"ocean city\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#f9e2af\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"right\">\n            <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">CONTACT</h5>\n            <p class=\"mbr-text desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".desc\">\n                Lorem ipsum dolor sit amet, pri omnium verterem id, sit labore dicunt an, ea civibus.</p>\n            <div mbr-form class=\"mbr-form\">\n                <!--Formbuilder Form-->\n                <form action name=\"Form Name\" method=\"POST\" class=\"mbr-form form-with-styler\">\n                    <div class=\"form-row\">\n                        <div hidden=\"hidden\" data-form-alert class=\"alert alert-success col-12\">Thanks for filling out\n                            the form!</div>\n                        <div hidden=\"hidden\" data-form-alert-danger class=\"alert alert-danger col-12\">Oops...! some\n                            problem!</div>\n                    </div>\n                    <div class=\"dragArea form-row\">\n                        <div class=\"col form-group \" data-for=\"email\">\n                            <input type=\"email\" name=\"email\" placeholder=\"Your Email\" data-form-field=\"email\" mbr-theme-style=\"display-7\" class=\"form-control\" value>\n                        </div>\n                        <div class=\"col-lg-12 col-md-12 col-sm-12 form-group\" data-for=\"textarea\">\n                            <textarea name=\"textarea\" placeholder=\"Your message\" data-form-field=\"textarea\" mbr-theme-style=\"display-7\" class=\"form-control\" style=\"margin-top: 0px; margin-bottom: 0px; height: 33px;\"></textarea>\n                        </div>\n                        <div class=\"col-auto\" mbr-buttons=\"true\" mbr-theme-style=\"display-4\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\"><a type=\"submit\" class=\"btn btn-black\" data-app-placeholder=\"Type Text\">Send</a></div>\n                    </div>\n                </form>\n                <!--Formbuilder Form-->\n            </div>\n        </div>\n        <div class=\"left\">\n            <div class=\"google-map\" mbr-map=\"googleMap\">\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "footer2-7",
          "_isUserblock": true,
          "_cid": "vd23YRXLkb",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bg-value",
            "transition": "background-color 0.3s ease-in-out",
            "&:hover": {
              "background-color": "@hoverColor"
            },
            ".mbr-section-title": {
              "margin": "0"
            },
            ".card-wrapper": {
              "z-index": "3"
            },
            ".full-link": {
              "position": "absolute !important",
              "top": "0",
              "left": "0",
              "width": "100%",
              "height": "100%",
              "font-size": "0",
              "z-index": "2"
            },
            ".popup-btn": {
              "&.card-wrapper": {
                "z-index": "1 !important"
              }
            }
          },
          "_name": "content3",
          "_sourceTheme": "restaurantm4",
          "_customHTML": "<section group=\"Content\" class=\"content3 restaurantm4_content3 popup-btn-cards\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" plugins=\"mbr-popup-btns\">\n\n\t<mbr-parameters>\n\t\t<!--Block parameters controls (Blue \"Gear\" panel) -->\n\t\t<input type=\"text\" title=\"Link\" name=\"linkValue\" value=\"http://www.mobiri.se\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"15\" step=\"1\" value=\"2\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"15\" step=\"1\" value=\"2\">\n\t\t<input type=\"range\" inline title=\"Min Height\" name=\"blockHeight\" min=\"1\" max=\"25\" step=\"1\" value=\"3\">\n\t\t<input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"color\" title=\"Background Color\" value=\"#f9e2af\" selected>\n\t\t</fieldset>\n\n\t\t<input type=\"color\" title=\"Hover Color\" name=\"hoverColor\" value=\"#e7dacc\">\n\t\t<!-- End block parameters -->\n\t</mbr-parameters>\n\n\t<a class=\"full-link\" href=\"{{linkValue}}\"></a>\n\t<div class=\"container card-wrapper\">\n\t\t<div class=\"row justify-content-center align-items-center\" mbr-style=\"{'min-height':blockHeight + 'vw'}\">\n\t\t\t<div class=\"col-sm-12 col-md-10 text-block align-center\">\n\t\t\t\t<h2 mbr-if=\"showTitle\" class=\"mbr-section-title mbr-fonts-style mbr-light mbr-white mbr-bold\" mbr-theme-style=\"display-2\" data-app-selector=\".mbr-section-title, .text-block\">\n\t\t\t\t\t1234 Irish Road Ocean City MD<br>info@singingsirenpub.com<br>757-222-2222</h2>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>",
